# 이 파일을 복사해서 .env 로 저장하고 실제 값을 입력하세요
# .env 파일은 절대 git에 올라가지 않습니다

# Flask 시크릿 키 (랜덤 문자열로 변경하세요)
FLASK_SECRET_KEY=your-secret-key-here

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Kakao OAuth
KAKAO_REST_API_KEY=your-kakao-rest-api-key
KAKAO_CLIENT_SECRET=your-kakao-client-secret

# 배포 URL (Railway 배포 시 실제 URL로 변경)
BASE_URL=http://127.0.0.1:5000

# 데이터베이스 (Railway PostgreSQL 사용 시 자동 설정됨)
# DATABASE_URL=postgresql://user:pass@host/dbname

# Groq AI (주가 변동 이유 분석 - 무료)
# https://console.groq.com 에서 발급
GROQ_API_KEY=your-groq-api-key

# DART (전자공시시스템) — 한국 주식 분기 실적 (선택)
# https://opendart.fss.or.kr 에서 무료 발급
DART_API_KEY=your-dart-api-key

# 토스증권 Open API — 실시간 시세 / 캔들(차트) / 환율 (선택)
# https://developers.tossinvest.com 에서 발급
# 미설정 시 자동으로 yfinance/네이버로 폴백됩니다
TOSS_CLIENT_ID=your-toss-client-id
TOSS_CLIENT_SECRET=your-toss-client-secret
# 토스 계좌 import 권한 제한 (앱 소유자 로그인 이메일)
TOSS_OWNER_EMAIL=
# (선택) 고정 IP 프록시 — Railway egress IP가 재배포마다 바뀌는 문제 해결용.
# 프록시 IP를 토스 콘솔에 1회 등록하면 됨. 예: http://user:pass@host:3128
TOSS_PROXY_URL=
